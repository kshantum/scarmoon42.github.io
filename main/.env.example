# ===========================================
# ПРИЛОЖЕНИЕ
# ===========================================
# Порт, на котором будет доступно приложение (для docker-compose)
APP_PORT=30543

# Образ приложения (для использования собранного в GitHub)
APP_IMAGE=ghcr.io/scarmoon42/sitedraft:latest

# Окружение (production/development)
NODE_ENV=production

# ===========================================
# БАЗА ДАННЫХ ПРИЛОЖЕНИЯ (PostgreSQL 17+)
# ===========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=myapp

# Для локальной разработки (не docker-compose)
DATABASE_URL=postgresql://postgres:password@localhost:5432/myapp?schema=public

# ===========================================
# REDIS (кэширование)
# ===========================================
# Для локальной разработки
REDIS_URL=redis://localhost:6379

# ===========================================
# KEYCLOAK (аутентификация)
# ===========================================
# База данных Keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak-password
KEYCLOAK_DB_NAME=keycloak

# Администратор Keycloak
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Realm и клиент для приложения
KEYCLOAK_REALM=app
KEYCLOAK_CLIENT_ID=frontend

# URL Keycloak
KEYCLOAK_URL=http://localhost:8080

# ===========================================
# FRONTEND (Vite)
# ===========================================
VITE_API_URL=http://localhost:3001
VITE_BASE_PATH=/
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=app
VITE_KEYCLOAK_CLIENT_ID=frontend

# ===========================================
# API
# ===========================================
PORT=3001

# CORS (разрешённые домены)
# Используйте * для всех доменов (только для разработки!)
CORS_ORIGIN=*
